rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'admin';
    }

    function isInstructor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'instructor';
    }

    function isAccountingSession() {
      return request.auth != null
        && exists(/databases/$(database)/documents/accountingSessionTokens/$(request.auth.uid))
        && get(/databases/$(database)/documents/accountingSessionTokens/$(request.auth.uid)).data.expiresAt > request.time;
    }

    function userEnrolledCourseIds() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(path) ? [] :
        (get(path).data.enrolledCourseIds != null ? get(path).data.enrolledCourseIds : []);
    }

    function userAssignedCourses() {
      let a = userDoc().assignedCourses;
      return a != null ? a : [];
    }

    function instructorOwnsCourse(courseId) {
      return exists(/databases/$(database)/documents/courses/$(courseId))
        && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid;
    }

    function instructorAssignedToCourse(courseId) {
      return courseId in userAssignedCourses();
    }

    function bootstrapAdminEnabled() {
      return exists(/databases/$(database)/documents/settings/bootstrap)
        && get(/databases/$(database)/documents/settings/bootstrap).data.enabled == true;
    }

    /* ── users ───────────────────────────────────────── */
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || isAdmin()
        || (isInstructor() && resource.data.role in ['student', 'user'])
      );
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (
          ((request.resource.data.role == 'student' || request.resource.data.role == 'user')
            && request.resource.data.status == 'approved')
          || bootstrapAdminEnabled()
        );
      allow update: if isSignedIn() && (
        isAdmin()
        || (request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.email == resource.data.email
          && request.resource.data.assignedCourses == resource.data.assignedCourses)
      );
      allow delete: if isAdmin();
    }

    /* ── courses ────────────────────────────────────── */
    match /courses/{courseId} {
      allow read: if true;
      allow create: if isAdmin() || (isInstructor() && request.resource.data.instructorId == request.auth.uid);
      allow update, delete: if isAdmin() || (isInstructor() && resource.data.instructorId == request.auth.uid);
    }

    /* ── exams ──────────────────────────────────────── */
    match /exams/{examId} {
      allow read: if isSignedIn() && (
        isAdmin() || isInstructor()
        || resource.data.courseId in userEnrolledCourseIds()
      );
      allow create: if isAdmin() || (isInstructor() && (
        instructorOwnsCourse(request.resource.data.courseId)
        || instructorAssignedToCourse(request.resource.data.courseId)
      ));
      allow update, delete: if isAdmin() || (isInstructor() && (
        instructorOwnsCourse(resource.data.courseId)
        || instructorAssignedToCourse(resource.data.courseId)
      ));
    }

    /* ── submissions ────────────────────────────────── */
    match /submissions/{subId} {
      allow read: if isSignedIn() && (
        isAdmin() || isInstructor()
        || resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isInstructor();
      allow delete: if isAdmin();
    }

    /* ── public collections ─────────────────────────── */
    match /news/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /trainers/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /programs/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id} { allow read: if true; allow write: if isAdmin(); }
    match /team/{id}         { allow read: if true; allow write: if isAdmin(); }

    /* ── settings ───────────────────────────────────── */
    match /settings/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() || bootstrapAdminEnabled();
      allow delete: if isAdmin() || bootstrapAdminEnabled();
    }

    /* Course enrollment applications — status: pending | approved | rejected (admin approves course access). */
    match /enrollmentRequests/{id} {
      allow create: if request.resource.data.keys().hasAll([
          'courseId', 'courseTitle', 'studentName', 'studentEmail', 'studentPhone',
          'createdAt', 'enrollmentStatus', 'userId'
        ])
        && request.resource.data.courseId is string
        && request.resource.data.studentEmail is string
        && request.resource.data.studentName is string
        && request.resource.data.studentPhone is string
        && request.resource.data.createdAt is string
        && request.resource.data.enrollmentStatus == 'pending'
        && (
          (request.auth == null && request.resource.data.userId == null)
          || (request.auth != null && request.resource.data.userId == request.auth.uid)
        );
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || (isSignedIn()
          && resource.data.studentEmail is string
          && resource.data.studentEmail == userDoc().email);
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }

    /* Path quiz — learners save recommendations (signed-in only). */
    match /pathQuizResults/{id} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['answers', 'recommendedCourseIds', 'createdAt', 'userId']);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    /* Service leads — anyone can create (public forms), only admin can read/update. */
    match /consultationLeads/{id} {
      allow create: if true;
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }
    match /hiringLeads/{id} {
      allow create: if true;
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }
    match /corporateLeads/{id} {
      allow create: if true;
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* OTP for password reset — written only by Cloud Functions (Admin SDK). */
    match /passwordResetOtps/{docId} {
      allow read, write: if false;
    }

    /* ── Accounting Module ──────────────────────────────────────────────────────
       Access model:
       - Financial collections: platform admins OR an active accountingSessionTokens session.
       - accountingUserRequests / accountingUsers: legacy; admin-only (no public writes).
       - accountingSessionTokens: created by anonymous auth for optional standalone /accounting flows.
       ──────────────────────────────────────────────────────────────────────── */
    match /accountingUserRequests/{id} {
      allow read, update: if isAdmin();
      allow create, delete: if false;
    }

    match /accountingUsers/{id} {
      // Password is hashed (SHA-256) — never store plaintext.
      allow read: if isAdmin() || isAccountingSession();
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['username','passwordHash','name','createdAt'])
        && request.resource.data.passwordHash is string
        && request.resource.data.passwordHash.size() == 64;
      allow update, delete: if false;
    }

    match /accountingSessionTokens/{uid} {
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasAll(['expiresAt'])
        && request.resource.data.expiresAt is timestamp;
      allow update, delete: if false;
    }

    match /accountingRounds/{id}             { allow read, write: if isAdmin() || isAccountingSession(); }
    match /accountingExpenses/{id}           { allow read, write: if isAdmin() || isAccountingSession(); }
    match /accountingSalaries/{id}           { allow read, write: if isAdmin() || isAccountingSession(); }
    match /accountingWithdrawals/{id}        { allow read, write: if isAdmin() || isAccountingSession(); }
    match /accountingMarketing/{id}          { allow read, write: if isAdmin() || isAccountingSession(); }
    match /accountingInstructorPayments/{id} { allow read, write: if isAdmin() || isAccountingSession(); }
    match /accountingMentorPayments/{id}     { allow read, write: if isAdmin() || isAccountingSession(); }

    match /{document=**} { allow read, write: if false; }
  }
}
