rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'admin';
    }

    function isInstructor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'instructor';
    }

    function userEnrolledCourseIds() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(path) ? [] :
        (get(path).data.enrolledCourseIds != null ? get(path).data.enrolledCourseIds : []);
    }

    function userAssignedCourses() {
      let a = userDoc().assignedCourses;
      return a != null ? a : [];
    }

    function instructorOwnsCourse(courseId) {
      return exists(/databases/$(database)/documents/courses/$(courseId))
        && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid;
    }

    function instructorAssignedToCourse(courseId) {
      return courseId in userAssignedCourses();
    }

    function bootstrapAdminEnabled() {
      return exists(/databases/$(database)/documents/settings/bootstrap)
        && get(/databases/$(database)/documents/settings/bootstrap).data.enabled == true;
    }

    /* ── users ───────────────────────────────────────── */
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || isAdmin()
        || (isInstructor() && resource.data.role in ['student', 'user'])
      );
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (
          ((request.resource.data.role == 'student' || request.resource.data.role == 'user')
            && request.resource.data.status == 'pending')
          || bootstrapAdminEnabled()
        );
      allow update: if isSignedIn() && (
        isAdmin()
        || (request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.email == resource.data.email
          && request.resource.data.assignedCourses == resource.data.assignedCourses)
      );
      allow delete: if isAdmin();
    }

    /* ── courses ────────────────────────────────────── */
    match /courses/{courseId} {
      allow read: if true;
      allow create: if isAdmin() || (isInstructor() && request.resource.data.instructorId == request.auth.uid);
      allow update, delete: if isAdmin() || (isInstructor() && resource.data.instructorId == request.auth.uid);
    }

    /* ── exams ──────────────────────────────────────── */
    match /exams/{examId} {
      allow read: if isSignedIn() && (
        isAdmin() || isInstructor()
        || resource.data.courseId in userEnrolledCourseIds()
      );
      allow create: if isAdmin() || (isInstructor() && (
        instructorOwnsCourse(request.resource.data.courseId)
        || instructorAssignedToCourse(request.resource.data.courseId)
      ));
      allow update, delete: if isAdmin() || (isInstructor() && (
        instructorOwnsCourse(resource.data.courseId)
        || instructorAssignedToCourse(resource.data.courseId)
      ));
    }

    /* ── submissions ────────────────────────────────── */
    match /submissions/{subId} {
      allow read: if isSignedIn() && (
        isAdmin() || isInstructor()
        || resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isInstructor();
      allow delete: if isAdmin();
    }

    /* ── public collections ─────────────────────────── */
    match /news/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /trainers/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /programs/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id} { allow read: if true; allow write: if isAdmin(); }
    match /team/{id}         { allow read: if true; allow write: if isAdmin(); }

    /* ── settings ───────────────────────────────────── */
    match /settings/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() || bootstrapAdminEnabled();
      allow delete: if isAdmin() || bootstrapAdminEnabled();
    }

    /* Enrollment notifications — written when a learner completes course registration (guest or logged-in). */
    match /enrollmentRequests/{id} {
      allow create: if request.resource.data.keys().hasAll(['courseId', 'courseTitle', 'studentName', 'studentEmail', 'createdAt'])
        && request.resource.data.courseId is string
        && request.resource.data.studentEmail is string;
      allow read, delete: if isAdmin();
      allow update: if isAdmin(); // Admin confirms/unconfirms payment
    }

    /* Path quiz — learners save recommendations (signed-in only). */
    match /pathQuizResults/{id} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['answers', 'recommendedCourseIds', 'createdAt', 'userId']);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
